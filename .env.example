# ==============================================================================
# Nectar Ingredients — Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to a new file named '.env.local' in the root directory
# and fill in the values below.
#
# IMPORTANT: Public variables (prefixed with NEXT_PUBLIC_) are embedded into
# the client bundle at build-time. All other variables are server-only secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Supabase Credentials (DB, Auth & Sessions)
# ------------------------------------------------------------------------------
# Obtain these from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret key required by the server routes to bypass Row Level Security (RLS)
# e.g., to create new users or write synced pricing data. Keep this secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ------------------------------------------------------------------------------
# 2. Sheet-to-DB Price Sync
# ------------------------------------------------------------------------------
# PRICE_SYNC_SECRET: A shared password of your choice (e.g. openssl rand -hex 32).
# Must match the SYNC_SECRET set in the Pricing Sheet Google Apps Script trigger.
PRICE_SYNC_SECRET=your-chosen-shared-price-sync-secret

# PRICE_SYNC_URL (Reference only): This is the URL you must paste into the Apps Script
# SYNC_URL variable so the Google Sheet knows where to send the price updates.
# Next.js/Vercel does not read this variable; it is for your reference only.
# PRICE_SYNC_URL=https://nectaringredients.vercel.app/api/sync-price

# ------------------------------------------------------------------------------
# 3. Email Gateway (Brevo SMTP API)
# ------------------------------------------------------------------------------
# Create an account on Brevo (formerly Sendinblue), create an API Key, and paste here:
BREVO_API_KEY=your-brevo-api-key

# ------------------------------------------------------------------------------
# 4. Paytm Payment Gateway Settings
# ------------------------------------------------------------------------------
# Obtain these from your Paytm Business Dashboard (https://business.paytm.com).
# Keep these blank in local development to automatically activate the friendly
# payment setup fallback mode.
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=
PAYTM_INDUSTRY_TYPE=
PAYTM_CHANNEL_ID=

# ------------------------------------------------------------------------------
# 5. Telegram Bot (Admin Alerts & Notifications)
# ------------------------------------------------------------------------------
# Token for your Telegram Bot (created via BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Chat ID where the bot should send direct checkout paid notifications
TELEGRAM_CHAT_ID=your-telegram-group-or-channel-chat-id

# ------------------------------------------------------------------------------
# 6. Google Apps Script Inquiry Router (Existing WholeSale Inquiry Flow)
# ------------------------------------------------------------------------------
# The Web App URL of your existing Apps Script that writes wholesale inquiries
# to your legacy tracking spreadsheet.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec

# ------------------------------------------------------------------------------
# 7. Opencode Zen API Key (Chatbot AI Support)
# ------------------------------------------------------------------------------
# API key used by the AI chatbot widget route (/api/chatbot)
OPENCODE_ZEN_API_KEY=your-chatbot-api-key
